# Copia este archivo a ".env" (sin ".example") y completa tus datos reales.
# El archivo ".env" NUNCA debe compartirse ni pegarse en un chat.

# --- Super admin (tú) ---
# Con estas credenciales entras al panel de administración para crear
# las cuentas de los padres y de los niños. Se aplican en cada arranque
# del servidor (si cambias la contraseña aquí, cambia también al reiniciar).
ADMIN_EMAIL=admin@ejemplo.com
ADMIN_PASSWORD=pon_una_contraseña_segura

# --- Envío de correo (opcional pero recomendado) ---
# Cuenta de Gmail desde la que se enviarán las contraseñas a los usuarios nuevos.
SMTP_USER=tu_correo@gmail.com
# Contraseña de aplicación de Gmail (16 caracteres, NO tu contraseña normal)
# Se genera en: https://myaccount.google.com/apppasswords
# (requiere tener activada la verificación en 2 pasos en la cuenta de Google)
SMTP_PASS=xxxxxxxxxxxxxxxx

# Si no configuras SMTP_USER/SMTP_PASS, las contraseñas de los usuarios nuevos
# se imprimen en la consola del servidor en vez de enviarse por correo.

# --- Red (solo importa en el VPS de producción, en tu computador déjalo así) ---
# Puerto del servidor (opcional, por defecto 5183)
PORT=5183
# En producción, detrás de nginx: HOST=127.0.0.1 (el puerto de Node no debe
# quedar expuesto directo a internet, solo nginx le habla). En tu computador
# para pruebas, déjalo vacío o en 0.0.0.0.
HOST=0.0.0.0
# En producción, con nginx como única puerta de entrada: TRUST_PROXY=1
# (así el rate-limit usa la IP real del visitante, no la de nginx).
# En tu computador, déjalo en 0.
TRUST_PROXY=0
