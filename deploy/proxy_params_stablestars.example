# Copia este archivo a /etc/nginx/proxy_params_stablestars (sin ".example")
# Cabeceras estándar para que la app en Node vea la IP y el protocolo reales
# del visitante (imprescindible para que TRUST_PROXY=1 funcione bien).

proxy_http_version 1.1;
proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;
proxy_set_header Connection "";
proxy_read_timeout 30s;
proxy_connect_timeout 5s;
